# Local PostgreSQL (Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flashcard

# Neon PostgreSQL (Production - uncomment to use)
# DATABASE_URL=postgresql://user:password@host/dbname

# Auth Secrets
AUTH_SECRET=your-secret-here
NUXT_AUTH_SECRET=your-secret-here

# Google OAuth (Required for Google Login)
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing one
# 3. Enable "Google+ API" in APIs & Services
# 4. Go to Credentials -> Create Credentials -> OAuth Client ID
# 5. Set Application type to "Web application"
# 6. Add Authorized redirect URI: http://localhost:3000/api/auth/google/callback
# 7. Copy Client ID and Client Secret below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App URL
NUXT_PUBLIC_APP_URL=http://localhost:3000
